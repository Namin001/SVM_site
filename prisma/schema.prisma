datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String   @id @default(cuid())
  username        String   @unique
  password        String
  role            String   @default("PARENT") // "ADMIN", "PARENT", "TEACHER"
  
  // Student Profile Fields
  name            String?
  admissionNo     String?  @unique
  age             Int?
  gender          String?
  className       String?  // e.g. "Class 10-A"
  birthCertPath   String?
  aadharPath      String?
  transferCertPath String?
  section         String?
  assignedTeacherIds String?
  imagePath       String?
  dob             String?
  joiningDate     String?
  subject         String?
  
  // New Demographic/Parent Fields
  fatherName      String?
  motherName      String?
  religion        String?
  caste           String?
  fatherPhone     String?
  motherPhone     String?
  
  // Fee Management
  feesPaid        Int      @default(0)
  
  // Teacher Profile Fields
  stream          String?
  maritalStatus   String?
  ugDegree        String?
  ugStream        String?
  certificatePath String?
  pgDetails       String?
  bedStatus       String? // "Yes", "No", "Pursuing"
  contactDetails  String? // Store phone/email if needed differently
  
  messages        Message[]
  createdGroups   Group[]  @relation("GroupCreator")
  groupMemberships GroupMember[]
  isActive        Boolean  @default(true)
  lastPromotedYear Int      @default(0)
  createdAt       DateTime @default(now())
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  members     GroupMember[]
  messages    Message[]
  createdById String
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id])
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("MEMBER") // "ADMIN", "MEMBER"
  lastReadAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Message {
  id              String   @id @default(cuid())
  content         String
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  className       String?  // Kept for backward compatibility
  groupId         String?
  group           Group?   @relation(fields: [groupId], references: [id])
  attachmentPath  String?
  attachmentType  String?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Content {
  id        String   @id @default(cuid())
  pageId    String   @unique // "home", "about", "newsletter"
  content   String
  updatedAt DateTime @updatedAt
}

model Post {
  id               String   @id @default(cuid())
  title            String
  subject          String?
  content          String
  imagePath        String?
  additionalImages String?  // Stringified JSON array of image paths
  videoPath        String?
  type             String   @default("NEWSLETTER") // "NEWSLETTER", "UPDATE", "ADMISSION", "EVENT"
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Application {
  id          String   @id @default(cuid())
  studentName String
  dob         String
  gender      String
  grade       String
  parentName  String
  phone       String
  email       String
  address     String
  status      String   @default("PENDING") // "PENDING", "REVIEWED", "ACCEPTED", "REJECTED"
  createdAt   DateTime @default(now())
}

model Class {
  id          String   @id @default(cuid())
  name        String   @unique
  defaultFees Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CareerApplication {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String
  domain      String
  domainOther String?
  
  // Education Details
  xMark       String?
  xMedium     String?
  xiiMark     String?
  xiiMedium   String?
  ugCgpa      String?
  ugStream    String?
  pgCgpa      String?
  pgStream    String?
  bedStatus   String? // "Yes", "No", "Pursuing"
  
  resumePath  String
  status      String   @default("RESUME_CHECKING")
  createdAt   DateTime @default(now())
}

